---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import { site } from "../site.config";

// Indexable: this is the product / money page.
const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "@id": `${site.url}/app#webapp`,
  name: site.name,
  url: `${site.url}/app/`,
  applicationCategory: "MultimediaApplication",
  operatingSystem: "Any (Chrome, Edge, Firefox, Safari)",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  publisher: { "@id": `${site.url}/#organization` },
};
---

<Layout
  title="Teleprompter — Paste Your Script & Record"
  description="Free online teleprompter. Paste your script, set the speed, and float it over your recording app. Nothing uploads — your script stays in your browser."
  path="/app/"
  jsonLd={[webAppSchema]}
>
  <Header />

  <main class="mx-auto max-w-[1100px] px-4 md:px-8 py-8 md:py-10">
    <header class="mb-6 text-center">
      <h1 class="text-2xl md:text-3xl font-semibold tracking-tight">
        Teleprompter
      </h1>
      <p class="mt-2 text-sm md:text-base text-[var(--color-fg-muted)]">
        Paste your script, press play, and
        <span class="text-[var(--color-fg)] font-medium">Float on top</span> of your
        recording app. Nothing is uploaded — your script never leaves this browser.
      </p>
    </header>

    {/* ============ EDITOR (shown before/while editing) ============ */}
    <section id="ftp-editor" class="mx-auto max-w-3xl">
      <label
        for="ftp-script"
        class="block text-sm font-medium text-[var(--color-fg)] mb-2"
      >
        Your script
      </label>
      <textarea
        id="ftp-script"
        rows="9"
        spellcheck="true"
        placeholder="Paste or type your script here. Tip: short paragraphs read best on camera…"
        class="w-full resize-y rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-subtle)] p-4 text-base leading-relaxed text-[var(--color-fg)] outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[color-mix(in_srgb,var(--color-accent)_30%,transparent)]"
      ></textarea>

      <div
        class="mt-2 flex flex-wrap items-center justify-between gap-2 text-xs text-[var(--color-fg-subtle)]"
      >
        <span id="ftp-meta">0 words · ~0 sec at 130 WPM</span>
        <button
          id="ftp-clear"
          type="button"
          class="rounded-md px-2 py-1 text-[var(--color-fg-muted)] hover:bg-[var(--color-bg-muted)] hover:text-[var(--color-fg)]"
        >
          Clear
        </button>
      </div>

      <div class="mt-5 flex flex-wrap items-center justify-center gap-3">
        <button
          id="ftp-start"
          type="button"
          class="ftp-control-btn ftp-control-btn-primary text-base px-6"
        >
          {/* play icon */}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"></path></svg>
          Start teleprompter
        </button>
      </div>
      <p class="mt-3 text-center text-xs text-[var(--color-fg-subtle)]">
        Your script is saved automatically in this browser only.
      </p>
    </section>

    {/* ============ PROMPTER (hidden until Start) ============ */}
    <section id="ftp-prompter" class="hidden">
      {/* Stage — THIS wrapper is what gets moved into the PiP window */}
      <div
        id="ftp-stage"
        class="ftp-stage mx-auto"
        style="height: min(60vh, 520px);"
      >
        <div id="ftp-viewport" class="ftp-viewport">
          <div id="ftp-track" class="ftp-track" style="font-size: 48px; line-height: 1.5; max-width: 80%;">
          </div>
        </div>
        <div id="ftp-eyeline" class="ftp-eyeline" aria-hidden="true"></div>
        <div id="ftp-status-badge" class="ftp-status-badge hidden">Paused</div>
        <div id="ftp-countdown" class="ftp-countdown hidden"></div>
        <div id="ftp-endcard" class="ftp-endcard hidden">
          <p class="text-xl font-semibold">Done 🎬</p>
          <button id="ftp-restart-end" type="button" class="ftp-control-btn ftp-control-btn-primary">
            Restart from top
          </button>
        </div>
      </div>

      {/* Progress + time */}
      <div class="mx-auto mt-3 flex max-w-3xl items-center gap-3">
        <div class="ftp-progress-track flex-1"><div id="ftp-progress" class="ftp-progress-fill"></div></div>
        <span id="ftp-time" class="text-xs tabular-nums text-[var(--color-fg-subtle)] whitespace-nowrap">0:00 left</span>
      </div>

      {/* Primary control strip */}
      <div class="mx-auto mt-4 flex max-w-3xl flex-wrap items-center justify-center gap-2">
        <button id="ftp-play" type="button" class="ftp-control-btn ftp-control-btn-primary" aria-keyshortcuts="Space">
          <span id="ftp-play-label">Play</span>
        </button>
        <button id="ftp-restart" type="button" class="ftp-control-btn" aria-keyshortcuts="R" title="Restart (R)">Restart</button>
        <button id="ftp-mirror" type="button" class="ftp-control-btn" aria-keyshortcuts="M" title="Mirror for beam-splitter rigs (M)">Mirror</button>
        <button id="ftp-float" type="button" class="ftp-control-btn" aria-keyshortcuts="P" title="Float on top of any app (P)">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 4h20v16H2z" opacity="0"></path><path d="M10 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6"></path><path d="M14 3h7v7"></path><path d="m21 3-9 9"></path></svg>
          Float on top
        </button>
        <button id="ftp-fullscreen" type="button" class="ftp-control-btn" aria-keyshortcuts="F" title="Fullscreen (F)">Fullscreen</button>
        <button id="ftp-edit" type="button" class="ftp-control-btn" title="Back to editing">Edit script</button>
        <button id="ftp-help" type="button" class="ftp-control-btn" aria-keyshortcuts="?" title="Keyboard shortcuts (?)" aria-label="Keyboard shortcuts">?</button>
      </div>

      {/* Settings sliders */}
      <div class="mx-auto mt-5 grid max-w-3xl grid-cols-1 gap-x-8 gap-y-4 sm:grid-cols-2">
        <div>
          <div class="flex items-center justify-between text-xs font-medium text-[var(--color-fg-muted)]">
            <label for="ftp-speed">Speed</label><span id="ftp-speed-val" class="tabular-nums">130 WPM</span>
          </div>
          <input id="ftp-speed" class="ftp-range mt-1.5" type="range" min="60" max="300" step="5" value="130" />
        </div>
        <div>
          <div class="flex items-center justify-between text-xs font-medium text-[var(--color-fg-muted)]">
            <label for="ftp-font">Font size</label><span id="ftp-font-val" class="tabular-nums">48 px</span>
          </div>
          <input id="ftp-font" class="ftp-range mt-1.5" type="range" min="24" max="96" step="2" value="48" />
        </div>
        <div>
          <div class="flex items-center justify-between text-xs font-medium text-[var(--color-fg-muted)]">
            <label for="ftp-lh">Line height</label><span id="ftp-lh-val" class="tabular-nums">1.5</span>
          </div>
          <input id="ftp-lh" class="ftp-range mt-1.5" type="range" min="1.1" max="2.4" step="0.1" value="1.5" />
        </div>
        <div>
          <div class="flex items-center justify-between text-xs font-medium text-[var(--color-fg-muted)]">
            <label for="ftp-width">Column width</label><span id="ftp-width-val" class="tabular-nums">80%</span>
          </div>
          <input id="ftp-width" class="ftp-range mt-1.5" type="range" min="40" max="100" step="5" value="80" />
        </div>
      </div>

      <label class="mx-auto mt-4 flex max-w-3xl items-center justify-center gap-2 text-sm text-[var(--color-fg-muted)]">
        <input id="ftp-countdown-toggle" type="checkbox" checked class="size-4 accent-[var(--color-accent)]" />
        Show a 3-2-1 countdown before scrolling
      </label>
    </section>

    {/* Keyboard shortcuts overlay */}
    <div id="ftp-shortcuts" class="ftp-shortcuts" hidden role="dialog" aria-modal="true" aria-label="Keyboard shortcuts">
      <div class="ftp-shortcuts-panel">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold">Keyboard shortcuts</h2>
          <button id="ftp-shortcuts-close" type="button" class="ftp-control-btn" aria-label="Close">✕</button>
        </div>
        <ul class="mt-4 space-y-2 text-sm text-[var(--color-fg-muted)]">
          <li class="flex items-center justify-between"><span>Play / Pause</span><kbd class="ftp-kbd">Space</kbd></li>
          <li class="flex items-center justify-between"><span>Speed up / down</span><span><kbd class="ftp-kbd">↑</kbd> <kbd class="ftp-kbd">↓</kbd></span></li>
          <li class="flex items-center justify-between"><span>Restart from top</span><kbd class="ftp-kbd">R</kbd></li>
          <li class="flex items-center justify-between"><span>Mirror mode</span><kbd class="ftp-kbd">M</kbd></li>
          <li class="flex items-center justify-between"><span>Float on top (Picture-in-Picture)</span><kbd class="ftp-kbd">P</kbd></li>
          <li class="flex items-center justify-between"><span>Fullscreen</span><kbd class="ftp-kbd">F</kbd></li>
          <li class="flex items-center justify-between"><span>This help</span><kbd class="ftp-kbd">?</kbd></li>
        </ul>

        <div class="mt-5 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-subtle)] p-4">
          <p class="text-sm font-semibold text-[var(--color-fg)]">🎧 Hands-free while floating</p>
          <p class="mt-1.5 text-xs text-[var(--color-fg-muted)] leading-relaxed">
            When you float the teleprompter over your recording app, keyboard shortcuts
            stop working because the browser loses focus. Use your keyboard's
            <strong class="text-[var(--color-fg)]">media keys</strong> (or a headset / Stream Deck)
            instead — they work even when another app is in front:
          </p>
          <ul class="mt-3 space-y-2 text-sm text-[var(--color-fg-muted)]">
            <li class="flex items-center justify-between"><span>Play / Pause</span><kbd class="ftp-kbd">⏯</kbd></li>
            <li class="flex items-center justify-between"><span>Speed up / down</span><span><kbd class="ftp-kbd">⏩</kbd> <kbd class="ftp-kbd">⏪</kbd></span></li>
            <li class="flex items-center justify-between"><span>Restart from top</span><kbd class="ftp-kbd">⏮</kbd></li>
          </ul>
          <p class="mt-2.5 text-[0.7rem] text-[var(--color-fg-subtle)] leading-relaxed">
            Desktop Chrome &amp; Edge only. We play a silent audio track so your computer
            routes the media keys to the teleprompter — nothing is recorded or heard.
          </p>
        </div>
      </div>
    </div>
  </main>

  <script>
    import { initTeleprompter } from "../lib/teleprompter";
    initTeleprompter();
  </script>
</Layout>
