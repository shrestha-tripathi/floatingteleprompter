---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../site.config";

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": `${site.url}/contact#contact`,
  url: `${site.url}/contact/`,
  name: `Contact ${site.shortName}`,
  description: `Get in touch with ${site.name} — bug reports, feature requests, and general questions.`,
  publisher: { "@id": `${site.url}/#organization` },
};

const githubLabel = site.githubRepo.replace(/^https?:\/\//, "");
const issuesUrl = `${site.githubRepo}/issues/new`;
---

<Layout
  title="Contact — get in touch"
  description={`Contact ${site.name} — email ${site.contactEmail} for general questions, or file a GitHub issue for bugs and feature requests.`}
  jsonLd={[contactSchema]}
>
  <Header />

  <main class="mx-auto max-w-[760px] px-6 md:px-12 py-16 md:py-24">
    <p class="text-sm uppercase tracking-[0.06em] text-[var(--color-fg-subtle)]">Contact</p>
    <h1 class="mt-4 text-4xl md:text-6xl font-semibold tracking-tight">Get in touch.</h1>
    <p class="mt-6 text-lg text-[var(--color-fg-muted)]">
      Bug to report? Feature you wish existed? Just want to say hi? Here's every way
      to reach {site.shortName}.
    </p>

    <hr class="my-12 border-[var(--color-border)]" />

    <section class="space-y-8">
      <!-- EMAIL -->
      <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-subtle)] p-6 md:p-8">
        <div class="flex items-start gap-4">
          <div class="shrink-0 size-10 rounded-md bg-[var(--color-bg)] border border-[var(--color-border)] flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="text-[var(--color-fg-muted)]" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="2" />
              <path d="M3 7l9 6 9-6" />
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <h2 class="text-xl font-semibold text-[var(--color-fg)]">Email</h2>
            <p class="mt-2 text-[var(--color-fg-muted)]">
              For general questions, partnership inquiries, or anything that doesn't fit
              anywhere else.
            </p>
            <a
              href={`mailto:${site.contactEmail}`}
              class="mt-3 inline-block text-[var(--color-accent)] font-mono text-sm underline break-all"
            >{site.contactEmail}</a>
            <p class="mt-2 text-sm text-[var(--color-fg-subtle)]">
              We typically respond within 2–3 business days.
            </p>
          </div>
        </div>
      </div>

      <!-- GITHUB -->
      <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-subtle)] p-6 md:p-8">
        <div class="flex items-start gap-4">
          <div class="shrink-0 size-10 rounded-md bg-[var(--color-bg)] border border-[var(--color-border)] flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-[var(--color-fg-muted)]" aria-hidden="true">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.03 1.76 2.7 1.25 3.36.96.1-.74.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18a10.9 10.9 0 015.74 0c2.19-1.49 3.15-1.18 3.15-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.83 1.18 3.09 0 4.42-2.7 5.4-5.26 5.68.41.36.78 1.06.78 2.14 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.56C20.21 21.38 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z" />
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <h2 class="text-xl font-semibold text-[var(--color-fg)]">GitHub Issues</h2>
            <p class="mt-2 text-[var(--color-fg-muted)]">
              The fastest way to reach us for bugs and feature requests. Public,
              searchable, and you can see if someone already reported it.
            </p>
            <a
              href={issuesUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-3 inline-flex items-center gap-1.5 text-[var(--color-accent)] font-mono text-sm underline"
            >
              File a new issue
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M7 17L17 7M9 7h8v8" />
              </svg>
            </a>
            <p class="mt-2 text-sm text-[var(--color-fg-subtle)]">
              Repo: <a href={site.githubRepo} target="_blank" rel="noopener noreferrer" class="font-mono text-[var(--color-fg-muted)] hover:text-[var(--color-fg)] underline">{githubLabel}</a>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- "Before you write" — funnels common questions to /faq -->
    <div class="mt-16 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-subtle)] p-6 md:p-8">
      <h2 class="text-xl md:text-2xl font-semibold text-[var(--color-fg)]">
        Before you write — check the FAQ
      </h2>
      <p class="mt-3 text-[var(--color-fg-muted)]">
        If your question is "is it really free?", "does it work over Zoom or OBS?", or
        "does my script get uploaded?" — the answer is probably already there.
      </p>
      <a
        href="/faq/"
        class="mt-6 inline-flex h-10 items-center rounded-md bg-[var(--color-accent)] px-5 text-sm font-semibold text-[var(--color-accent-fg)] no-underline transition-opacity hover:opacity-90"
      >
        Read the FAQ →
      </a>
    </div>

    <p class="mt-12 text-sm text-[var(--color-fg-subtle)]">
      {site.name} is built by <strong class="text-[var(--color-fg-muted)]">{site.author}</strong>
      as an independent project. There's no company and no support team — just one person
      who reads every email.
    </p>
  </main>

  <Footer />
</Layout>
