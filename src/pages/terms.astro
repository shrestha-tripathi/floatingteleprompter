---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site, absoluteUrl } from "../site.config";

const updated = "June 2026";

// WebPage JSON-LD — layered on sitewide Org + WebSite + auto-breadcrumb.
const termsSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": absoluteUrl("/terms/"),
  name: `Terms of Use — ${site.name}`,
  url: absoluteUrl("/terms/"),
  description: `The terms for using ${site.name}, a free browser-based teleprompter.`,
  isPartOf: { "@id": `${site.url}/#website` },
  publisher: { "@id": `${site.url}/#organization` },
};
---

<Layout
  title="Terms of Use"
  description={`The simple terms for using ${site.name}, a free browser-based teleprompter.`}
  path="/terms/"
  jsonLd={[termsSchema]}
  noindex={false}
>
  <Header />

  <main class="mx-auto max-w-[760px] px-6 md:px-12 py-16 md:py-24">
    <p class="text-sm uppercase tracking-[0.06em] text-[var(--color-fg-subtle)]">Legal</p>
    <h1 class="mt-4 text-4xl md:text-5xl font-semibold tracking-tight">Terms of Use</h1>
    <p class="mt-4 text-sm text-[var(--color-fg-subtle)]">Last updated: {updated}</p>

    <div class="mt-10 space-y-8 text-[var(--color-fg-muted)] leading-relaxed">
      <p>
        By using {site.name} (the “Service”) you agree to these terms. They're meant
        to be fair and readable, not a wall of legalese.
      </p>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-fg)]">The Service</h2>
        <p class="mt-3">
          {site.name} is a free, browser-based teleprompter. It runs on your device,
          stores your script only in your browser, and requires no account. We offer it
          as-is for personal and commercial recording use.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-fg)]">Acceptable use</h2>
        <p class="mt-3">
          Use the Service lawfully. Don't attempt to disrupt it, abuse it, or use it to
          create or present content that is illegal or infringes others' rights. You are
          responsible for the script you write and the recordings you make.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-fg)]">Your content</h2>
        <p class="mt-3">
          Your script is yours. Because it never leaves your device, we claim no rights
          to it and have no access to it.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-fg)]">No warranty</h2>
        <p class="mt-3">
          The Service is provided “as is,” without warranties of any kind. We don't
          guarantee it will be uninterrupted, error-free, or compatible with every
          browser or recording setup. Always test your setup before an important
          recording.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-fg)]">Limitation of liability</h2>
        <p class="mt-3">
          To the maximum extent permitted by law, {site.name} and its maker are not
          liable for any indirect, incidental, or consequential damages arising from
          your use of the Service, including any missed, lost, or unsatisfactory
          recordings.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-fg)]">Changes</h2>
        <p class="mt-3">
          We may update these terms; the “last updated” date will reflect any change.
          Continuing to use the Service means you accept the current terms.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-fg)]">Governing law</h2>
        <p class="mt-3">
          These terms are governed by the laws of {site.jurisdiction}, without regard
          to conflict-of-law principles.
        </p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-[var(--color-fg)]">Contact</h2>
        <p class="mt-3">
          Questions? Email
          <a href={`mailto:${site.contactEmail}`} class="text-[var(--color-accent)] underline">{site.contactEmail}</a>.
        </p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
