# ---------------------------------------------------------------------------
# Floating Teleprompter — environment variables (all OPTIONAL; sane defaults in
# src/site.config.ts). Copy to `.env` and override per-deploy as needed.
#
# Brand strings are env-driven so a domain rename is a `.env`-only change.
# The .pages.dev guard in site.config.ts rejects any *.pages.dev value here.
# ---------------------------------------------------------------------------

# Canonical site origin (protocol + domain, no trailing slash).
PUBLIC_SITE_URL=https://floatingteleprompter.com

# Bare domain (no protocol) — shown in copy + used in robots/sitemap.
PUBLIC_SITE_DOMAIN=floatingteleprompter.com

# Brand names.
PUBLIC_SITE_NAME=Floating Teleprompter
PUBLIC_SITE_SHORT_NAME=Teleprompter

# Short tagline (feeds homepage <title> + OG alt).
PUBLIC_SITE_TAGLINE=A teleprompter that floats over any app

# Meta description (<160 chars ideal).
PUBLIC_SITE_DESCRIPTION=Free online teleprompter that floats over OBS, Zoom, Loom and any recording app. Paste your script, hit play, look at the camera. No install, no signup — runs entirely in your browser.

# Maker credit for About/Contact (E-E-A-T trust signal).
PUBLIC_SITE_AUTHOR=Shrestha Tripathi

# Trust-page contact email.
PUBLIC_SITE_CONTACT_EMAIL=shrestha.tripathi@gmail.com

# Public source repo.
PUBLIC_SITE_GITHUB_REPO=https://github.com/shrestha-tripathi/floatingteleprompter

# Governing-law jurisdiction for Terms.
PUBLIC_SITE_JURISDICTION=India

# Google Analytics 4 Measurement ID (format G-XXXXXXXXXX). Leave EMPTY to
# disable analytics entirely. Only injected in production builds.
PUBLIC_GA_MEASUREMENT_ID=
